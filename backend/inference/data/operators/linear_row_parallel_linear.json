{
  "name": "RowParallelLinear",
  "description": "TP Row-Parallel Linear: weight sharded along in_features dimension, all-reduce on output",
  "inputs": [
    {
      "name": "x_shard",
      "shape": "[B, S, hidden_dim]",
      "dtype": "fp16"
    }
  ],
  "params": [
    {
      "name": "weight_shard",
      "shape": "[intermediate_dim, hidden_dim]",
      "dtype": "fp16"
    }
  ],
  "outputs": [
    {
      "name": "y",
      "shape": "[B, S, intermediate_dim]",
      "dtype": "fp16"
    }
  ],
  "compute_flops": "2 * B * S * hidden_dim * intermediate_dim * fp16",
  "module": "attn.o_proj",
  "category": "Linear"
}
