{
  "name": "RMSNormGated",
  "description": "Gated RMS Normalization: rms_norm(x) * gate where gate is a learned or computed parameter",
  "inputs": [
    {
      "name": "x",
      "shape": "[B, S, hidden_dim]",
      "dtype": "fp16"
    },
    {
      "name": "gate",
      "shape": "[B, S, hidden_dim]",
      "dtype": "fp16"
    }
  ],
  "params": [
    {
      "name": "weight",
      "shape": "[hidden_dim]",
      "dtype": "fp16"
    }
  ],
  "outputs": [
    {
      "name": "y",
      "shape": "[B, S, hidden_dim]",
      "dtype": "fp16"
    }
  ],
  "compute_flops": "5 * B * S * hidden_dim",
  "module": "norm.rms_gated",
  "category": "Normalization"
}
