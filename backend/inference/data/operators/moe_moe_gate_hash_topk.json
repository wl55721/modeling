{
  "name": "MoEGateHashTopK",
  "description": "MoE Gate with Hash: hash-based expert routing for load-balanced deterministic assignment",
  "inputs": [
    {
      "name": "x",
      "shape": "[B, S, hidden_dim]",
      "dtype": "fp16"
    },
    {
      "name": "token_ids",
      "shape": "[B, S]",
      "dtype": "int64"
    }
  ],
  "params": [
    {
      "name": "gate_weight",
      "shape": "[num_experts, hidden_dim]",
      "dtype": "fp32"
    }
  ],
  "outputs": [
    {
      "name": "expert_indices",
      "shape": "[B, S, top_k]",
      "dtype": "int32"
    },
    {
      "name": "expert_weights",
      "shape": "[B, S, top_k]",
      "dtype": "fp16"
    }
  ],
  "compute_flops": "2*B*S*hidden_dim*num_experts*fp32 + 7*B*S*num_experts*fp32",
  "module": "moe.gate_topk",
  "category": "MoE"
}
