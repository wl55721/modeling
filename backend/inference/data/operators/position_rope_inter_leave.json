      "shape": "[B, S, num_attention_heads // tp_size, head_dim]",
      "dtype": "bf16"
    }
  ],
  "params": [],
  "outputs": [
    {
      "name": "q_out",
      "shape": "[B, S, num_attention_heads // tp_size, head_dim]",
      "dtype": "bf16"
    },
    {
      "name": "k_out",
      "shape": "[B, S, num_attention_heads // tp_size, head_dim]",
      "dtype": "bf16"
    }
  ],
  "compute_flops": "6 * B * S * num_attention_heads // tp_size * head_dim * bf16",
  "module": "pos.rope_interleave",
