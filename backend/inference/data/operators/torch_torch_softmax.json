    }
  ],
  "params": [],
  "outputs": [
    {
      "name": "y",
      "shape": "[B, S, hidden_dim]",
      "dtype": "fp16"
    }
  ],
  "compute_flops": "B * S * hidden_dim * fp16",
  "module": "attn",
  "category": "Torch"
}
