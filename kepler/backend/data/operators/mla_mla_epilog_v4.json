{
  "name": "MLAEpilogV4",
  "description": "MLA Epilog DeepSeek-V4: projects attention output back to hidden_size after Multi-Head Latent Attention",
  "inputs": [
    {
      "name": "attn_out",
      "shape": "[B, S, o_groups, num_attention_heads * head_dim // o_groups]",
      "dtype": "fp16"
    }
  ],
  "params": [
    {
      "name": "wo_a",
      "shape": "[o_groups * o_lora_rank // o_tp_size, num_attention_heads * head_dim // o_groups]",
      "dtype": "fp16"
    },
    {
      "name": "wo_b",
      "shape": "[hidden_size, o_groups * o_lora_rank // o_tp_size]",
      "dtype": "fp8"
    }
  ],
  "outputs": [
    {
      "name": "y",
      "shape": "[B, S, hidden_size]",
      "dtype": "fp16"
    }
  ],
  "compute_flops": "2*B*S*o_groups*o_lora_rank//o_tp_size*num_attention_heads*head_dim//o_groups*fp16 + 2*B*S*o_groups*o_lora_rank//o_tp_size*hidden_size*fp8",
  "module": "attn.o_proj",
  "category": "MLA"
}
