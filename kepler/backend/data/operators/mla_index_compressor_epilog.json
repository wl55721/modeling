{
  "name": "IndexCompressorEpilog",
  "description": "Index Compressor Epilog: reconstructs routing indices from compressed representation",
  "inputs": [
    {
      "name": "compressed_idx",
      "shape": "[B, S // compress_ratio, index_head_dim]",
      "dtype": "fp16"
    }
  ],
  "params": [],
  "outputs": [
    {
      "name": "indices",
      "shape": "[B, S // compress_ratio, index_head_dim]",
      "dtype": "fp8"
    }
  ],
  "compute_flops": "factor * 2 * B * S // compress_ratio * index_head_dim * fp16",
  "module": "attn.compressor",
  "category": "MLA",
  "red_tips": "factor=1(prefill), 0.25(decode, compress_ratio=4), 0.008(decode, compress_ratio=128)"
}
