{
  "name": "RMSNormQuant",
  "description": "RMS Normalization with quantization: quant(rms_norm(x))",
  "inputs": [
    {
      "name": "x",
      "shape": "[B, S, hidden_size]",
      "dtype": "fp16"
    }
  ],
  "params": [],
  "outputs": [
    {
      "name": "y",
      "shape": "[B, S, hidden_size]",
      "dtype": "int8"
    },
    {
      "name": "scale",
      "shape": "[B, S]",
      "dtype": "fp32"
    }
  ],
  "compute_flops": "4 * B * S * hidden_size * fp32 + 2 * B * S * hidden_size * fp16",
  "module": "norm",
  "category": "Normalization"
}
